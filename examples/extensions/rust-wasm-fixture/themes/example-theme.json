{
  "schema_version": 1,
  "id": "example_theme",
  "display_name": "Example Night Market",
  "description": "A deliberately visible sample extension theme for testing Oino theme selection and preview.",
  "mode": "dark",
  "inherits": "system",
  "palette": {
    "bg": "#071013",
    "surface": "#102027",
    "surface_raised": "#18313a",
    "fg": "#ecfeff",
    "muted": "#8fb8c5",
    "accent": "#f59e0b",
    "accent_alt": "#22d3ee",
    "success": "#4ade80",
    "warning": "#fbbf24",
    "error": "#fb7185",
    "selection": "#374151",
    "selection_fg": "#ffffff"
  },
  "tokens": {
    "app.bg": "$palette.bg",
    "app.fg": "$palette.fg",
    "app.border_focused": "$palette.accent",
    "panel.bg": "$palette.surface",
    "panel.border": "#31505b",
    "panel.border_focused": "$palette.accent",
    "panel.title": "$palette.accent",
    "composer.bg": "$palette.surface_raised",
    "composer.border_focused": "$palette.accent_alt",
    "list.selected_bg": "$palette.selection",
    "list.selected_fg": "$palette.selection_fg",
    "status.fg": "$palette.muted",
    "status.success": "$palette.success",
    "status.warning": "$palette.warning",
    "status.error": "$palette.error",
    "status.working": "$palette.accent_alt",
    "message.user.border": "$palette.accent",
    "message.user.fg": "$palette.fg",
    "message.assistant.border": "$palette.accent_alt",
    "message.assistant.fg": "$palette.fg",
    "tool.border": "$palette.warning",
    "tool.title": "$palette.warning",
    "markdown.link": "$palette.accent_alt",
    "markdown.code_border": "$palette.accent"
  }
}
