{
  "id": "oino.vcc",
  "display_name": "Oino VCC",
  "version": "0.1.0",
  "oino": "^0.1",
  "publisher": "oino",
  "description": "Optional built-in deterministic session compaction and recall for Oino.",
  "extensions": [
    {
      "manifest": "extensions/vcc/oino.extension.json",
      "enabled_by_default": true
    }
  ],
  "resources": [],
  "assets": [],
  "examples": [],
  "docs": [
    {
      "path": "docs/README.md"
    }
  ],
  "dependencies": [],
  "permissions": {
    "tools": [
      "vcc_recall"
    ],
    "commands": [
      "compact",
      "recall"
    ],
    "host_capabilities": [
      "vcc_compaction",
      "vcc_recall"
    ],
    "ui": [],
    "filesystem": [],
    "shell_process": {
      "allowed": false,
      "commands": []
    },
    "network": {
      "raw_network": false,
      "hosts": []
    },
    "secrets": [],
    "session_persistence": [
      "session"
    ],
    "provider_mutation": [],
    "package_management": []
  },
  "trust": {
    "reviewed": true,
    "publisher": "oino",
    "advisories": []
  }
}
